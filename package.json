{
  "name": "example-basic",
  "type": "module",
  "scripts": {
    "generate:cms": "tsx scripts/generate-cms-config.ts",
    "generate:cms:dev": "tsx scripts/generate-cms-config.ts --dev",
    "validate:content": "tsx scripts/validate-content.ts",
    "predev": "npm run generate:cms:dev",
    "dev": "concurrently --names \"CLIENT,ADMIN,DECAP,CMS\" --hide \"DECAP\" --pad-prefix --prefix-colors \"cyan,magenta,yellow,green\" \"NODE_OPTIONS=--inspect vite dev\" \"npm run dev:admin\" \"decap-server\" \"npm run dev:cms\"",
    "dev:admin": "vite dev --config vite.config.admin.ts",
    "dev:cms": "tsx scripts/generate-cms-config.ts --dev --watch",
    "prebuild": "npm run generate:cms && npm run build:admin && npm run validate:content",
    "build": "vite build && vite build --config vite.config.admin.ts",
    "build:admin": "vite build --config vite.config.admin.ts",
    "start": "vite start",
    "preview": "vite preview"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/lodash": "^4.17.24",
    "cva": "npm:class-variance-authority@^0.7.1",
    "decap-cms-app": "^3.12.2",
    "gray-matter": "^4.0.3",
    "lodash": "^4.18.1",
    "marked": "^18.0.3",
    "solid-js": "^1.9.5",
    "tailwindcss": "^4.3.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "concurrently": "^9.2.1",
    "decap-server": "^3.7.0",
    "js-yaml": "^4.1.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
